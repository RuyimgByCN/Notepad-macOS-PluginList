{
  "identifier": "xbrackets",
  "name": "XBrackets Lite",
  "version": "1.0.0",
  "description": "Autocompletion of brackets. macOS native port (CLI wrapper).",
  "author": "Vitaliy Dovgan",
  "homepage": "https://github.com/d0vgan/npp-XBracketsLite",
  "entryPoint": "xbrackets.sh",
  "commands": [
